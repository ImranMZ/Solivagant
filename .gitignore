```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific
.vscode/
.idea/

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.out
*.exe
*.dll
*.so
*.a

# Dependencies
node_modules/
.venv/
venv/
.mypy_cache/
.pytest_cache/
```